# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# uploaded images
/public/uploads/
public/downloads/*.dmg

# scripts: operational scripts are committed (bulk-seed, refresh-covers, etc.)
# but generated outputs are not
/scripts/sample-output/

# log files
dev.log
*.log

# temporary files
*.tmp
*.temp

# local backups (sensitive data)
/local-backups/
dev.db
prisma/dev.db
.env*.local
*.bak

# Claude Code local agent memory & scheduled tasks
/.claude/

# Lighthouse audit outputs (regeneratable)
/lighthouse-reports/

# ────────────────────────────────────────────────────────
# 사이트
# ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Cron 인증용 임의 문자열. `openssl rand -hex 32`로 생성 권장.
CRON_SECRET=

# Admin 페이지 Basic Auth 비밀번호 (default: admin123)
ADMIN_PASSWORD=

# ────────────────────────────────────────────────────────
# 데이터베이스 — Turso (LibSQL)
# ────────────────────────────────────────────────────────
# DATABASE_URL은 Prisma CLI 호환용 placeholder (실제 connection은 TURSO_*)
DATABASE_URL=file:./dev.db
TURSO_DATABASE_URL=libsql://[your-db-name].turso.io
TURSO_AUTH_TOKEN=
DATABASE_AUTH_TOKEN=  # = TURSO_AUTH_TOKEN과 동일하게 설정 (Prisma 어댑터용)

# ────────────────────────────────────────────────────────
# AI — 콘텐츠 생성
# ────────────────────────────────────────────────────────
# 둘 중 하나 이상 필요. Claude는 일일 한도 더 넉넉, Gemini는 무료 한도 빠르게 소진.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ────────────────────────────────────────────────────────
# 이미지 — Cover 자동 검색
# ────────────────────────────────────────────────────────
# https://unsplash.com/developers — Demo tier 시간당 50 req 무료
UNSPLASH_ACCESS_KEY=

# ────────────────────────────────────────────────────────
# 선택
# ────────────────────────────────────────────────────────
# YouTube 채널 동기화 (현재 cron OFF)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# 글 발행 후 Vercel 자동 재배포
REDEPLOY_WEBHOOK_URL=

# Vercel Blob 이미지 업로드
BLOB_READ_WRITE_TOKEN=

# GitHub Actions에서 워크플로 도메인 호출용
SITE_URL=
